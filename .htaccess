RewriteEngine On

# 1. Paksa bersihkan URL (Jika user/aplikasi mengakses file.php, otomatis redirect ke /file)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# 2. Jalankan file PHP di balik layar secara transparan
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^([^/]+)$ $1.php [L]